# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/luminary-x?retryWrites=true&w=majority

# Auth
JWT_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Admin seed credentials (used only by npm run seed)
ADMIN_EMAIL=admin@luminaryx.com
ADMIN_PASSWORD=Admin@123456
